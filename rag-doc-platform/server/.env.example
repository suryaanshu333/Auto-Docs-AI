# Server environment variables example
# Copy this file to server/.env and fill values before running

# API keys
GROQ_API_KEY=your_groq_api_key_here
JOOBLE_API_KEY=your_jooble_api_key_or_leave_blank

# Server
PORT=5000
CHROMA_URL=http://chromadb:8000

# Database
MONGO_URL=mongodb://localhost:27017/rag-doc-platform

# JWT
JWT_SECRET=replace_with_a_long_random_string

# Email (optional - for verification)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com

# Frontend URL (used when generating share links)
FRONTEND_URL=http://localhost:5173
