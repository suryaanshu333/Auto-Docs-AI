# Production environment variables for Render deployment
# NOTE: Do NOT commit this file. Set these in Render dashboard instead.

# Backend
NODE_ENV=production
PORT=5000
MONGO_URL=your-mongodb-atlas-url-here
CHROMA_URL=your-chromadb-url-here
GROQ_API_KEY=your-groq-key-here
JOOBLE_API_KEY=your-jooble-key-here
JWT_SECRET=your-secure-jwt-secret-here
FRONTEND_URL=https://rag-doc-client.onrender.com

# Client
VITE_API_URL=https://rag-doc-backend.onrender.com
